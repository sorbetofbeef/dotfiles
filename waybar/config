  },
  
  "network": {
    "format-wifi": "๎ฃณ",
    "format-disconnected": "๎ค",
    "tooltip-format": "{essid}"
  },

  "custom/pacman": {
    "format": "{} ๎ขก",
    "interval": 43200,
    "exec": "expr $(paru -Syuqp | wc -l) - 5",
    "exec-if": "pacwrap",
    "on-click": "kitty --hold paru -Syu; pkill -SIGRTMIN+8 waybar",
    "signal": 8
  },

  "bluetooth": {
    "format": "{icon}",
    "format-disabled": "",
    "format-alt": "bluetooth: {status}",
    "format-icons": {
      "enabled": "๎ฉบ",
      "disabled": "๎ฉฉ"
    },
    "tooltip-format": "{status}"
  },

  "custom/power": {
    "format": "๎ขด",
    "on-click": "power-wrapper",
    "tooltip-format": "alacritty --hold --class \"Launcher\" --title \"Power\" -e power-wrapper",
    "tooltip": false,
  },

  "pulseaudio": {
    "states": {
      "extreme": 101,
      "high": 90,
      "good": 60,
      "low": 30,
      "lowest": 0,
    },
    "format-muted": "๎ฃฎ",
    "format": "{icon}",
    "format-icons": {
      "default": [ "๎ฃฑ", "๎ฃฏ", "๎ฃฐ"],
    },
    "on-click": "alacritty --class \"Launcher\" --title \"Volume\" -e volume-control",
    "tooltip-format": "{volume}",
  },

   "custom/mpd": {
