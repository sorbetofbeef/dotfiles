  "clock": {
    "format": " {:%A %B, %d %Y  %H:%M} ",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
  },
  
  "battery": {
    "states": {
      "critical": 14
    },
    "format": "{icon}",
    "format-critical": "{icon}",
    "format-icons":  [ "๎พน๎พน๎พน",  "๎ฟ๎พน๎พน", "๎พต๎พน๎พน", "๎พต๎ฟ๎พน", "๎พต๎พต๎พน", "๎พต๎พต๎ฟ", "๎พต๎พต๎พต" ],
