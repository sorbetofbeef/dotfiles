  "clock": {
    "format": " {:%A %B, %d %Y  %H:%M} ",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
  },
  
  "battery": {
    "states": {
      "critical": 14
    },
    "format": "{icon}",
    "format-critical": "{icon}",
    "format-icons":  [ "оҫ№оҫ№оҫ№",  "оҝҶоҫ№оҫ№", "оҫөоҫ№оҫ№", "оҫөоҝҶоҫ№", "оҫөоҫөоҫ№", "оҫөоҫөоҝҶ", "оҫөоҫөоҫө" ],
    "tooltip": "{capacity}"
  },
  
  "network": {
    "format-wifi": "оЈі",
    "format-disconnected": "оӨҮ",
    "tooltip-format": "{essid}"
  },

  "custom/pacman": {
    "format": "{} оўЎ",
    "interval": 43200,
    "exec": "expr $(paru -Syuqp | wc -l) - 5",
    "exec-if": "pacwrap",
    "on-click": "kitty --hold paru -Syu; pkill -SIGRTMIN+8 waybar",
    "signal": 8
  },

  "bluetooth": {
    "format": "{icon}",
    "format-disabled": "",
    "format-alt": "bluetooth: {status}",
    "format-icons": {
      "enabled": "о©ә",
      "disabled": "о©©"
    },
    "tooltip-format": "{status}"
  },

  "custom/power": {
    "format": "оўҙ",
    "on-click": "power-wrapper",
    "tooltip-format": "alacritty --hold --class \"Launcher\" --title \"Power\" -e power-wrapper",
    "tooltip": false,
  },

  "pulseaudio": {
    "states": {
      "extreme": 101,
      "high": 90,
      "good": 60,
      "low": 30,
      "lowest": 0,
    },
    "format-muted": "оЈ®",
    "format": "{icon}",
    "format-icons": {
      "default": [ "оЈұ", "оЈҜ", "оЈ°"],
    },
    "on-click": "alacritty --class \"Launcher\" --title \"Volume\" -e volume-control",
    "tooltip-format": "{volume}",
  },

   "custom/mpd": {
        "format": " пҖҘ   {}",
        "max-length": 35,
        "interval": 10,
        "exec": "mpc current",
        "exec-if": "pgrep mpd",
        "on-click": "mpc toggle",
        "on-scroll-up": "mpc next",
        "on-scroll-down": "mpc prev",
        "on-click-right": "kitty -1 'ncmpcpp'"
    },

  "custom/right-cap": {
    "format": " ",
  },

  "custom/left-cap": {
    "format": " ",
  },

  "custom/right-backed": {
    "format": "оғҮ",
     "interval": 10,
     "exec": "mpc current",
     "exec-if": "pgrep mpd",
  },

  "custom/left-backed": {
    "format": "оғҶ",
     "interval": 10,
     "exec": "mpc current",
     "exec-if": "pgrep mpd",
  },


  "custom/spacer": {
    "format": " ",
  },
